# Public base URL of this app (no trailing path). Used by the Auth0 SDK; must match URLs in the Auth0 application.
APP_BASE_URL=http://localhost:3000

# Auth0 tenant and application
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Session cookie secret (e.g. openssl rand -hex 32)
AUTH0_SECRET=

# API identifier in Auth0 — omit only if the frontend never calls arvo-auth with a bearer token
AUTH0_AUDIENCE=

# Optional: arvo-auth API origin — enables POST to /api/operator/auth/logout on sign-out
NEXT_PUBLIC_API_BASE_URL=
